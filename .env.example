# SiliconFlow image generation API key.
# Create one at https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY="MY_SILICONFLOW_API_KEY"

# Required access password for the login screen.
APP_PASSWORD="CHANGE_ME_TO_A_STRONG_PASSWORD"

# Optional signing secret for login cookies. If omitted, APP_PASSWORD is used.
AUTH_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET"

# Optional default image model. The frontend can still choose a model in Settings.
IMAGE_MODEL="black-forest-labs/FLUX.1-dev"

# Optional app URL for deployment notes or external integrations.
APP_URL="http://localhost:3000"
